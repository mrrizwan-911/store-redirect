# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/

# next.js
/.next/
.claude/
/out/
docs/
playwright-report/
playwright/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
playwright-report/
tests/
playwright.config.ts
vitest.config.ts

# Extra files (only source code)
public/moke/
*.tsbuildinfo
.env.example

# Source code testing files
src/**/*.test.ts
src/**/*.test.tsx
src/**/*.spec.ts
src/**/*.spec.tsx
testsprite_tests/

# Scripts and extra tests
check-db.ts
scripts/
tests/
# Additional exclusions
get-errors.patch
.testsprite/
jest.config.js
